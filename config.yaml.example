# AI Gateway 配置示例
# 复制为 config.yaml 并填入真实 API Key

# 服务端配置（重要：这些配置必须生效，鉴权/超时才能工作）
server:
  # 入站鉴权 Token 列表（Bearer 验证）
  # 为空则关闭鉴权（仅本地开发）
  auth_tokens:
    - "***"
  
  # 请求限制（默认 10MB）
  max_body_size: 10485760
  
  # 超时设置（秒）
  timeouts:
    connect: 10   # 连接上游超时
    request: 300  # 非流式请求总超时

# Provider 配置（每个 provider 必须指定 type: openai | anthropic）
providers:
  openai:
    type: openai
    api_key: "your-openai-api-key"
    base_url: "https://api.openai.com/v1"
    models:
      - "gpt-4o"
      - "gpt-4o-mini"
      - "gpt-3.5-turbo"

  anthropic:
    type: anthropic
    api_key: "your-anthropic-api-key"
    base_url: "https://api.anthropic.com"
    models:
      - "claude-sonnet-4-5"

  # Ollama 本地模型
  ollama:
    type: openai  # Ollama 兼容 OpenAI 协议
    api_key: "ollama"
    base_url: "http://localhost:11434/v1"
    models:
      - "llama3.2"
      - "qwen2.5"

  # 火山方舟（兼容 Anthropic 协议）
  # ⚠️ 注意：base_url 不要以 /v1 结尾，代码会自动补全
  ark:
    type: anthropic
    api_key: "your-ark-api-key"
    base_url: "https://ark.cn-beijing.volces.com/api/coding"
    models:
      - "glm-5.1"

# 模型别名（简化为仅映射模型名）
aliases:
  fast: gpt-4o-mini      # 等价于 model: gpt-4o-mini
  strong: claude-sonnet-4-5
